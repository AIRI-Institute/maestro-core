# Environment variables for running CARL examples
# Copy this file to .env and fill in your values

# OpenAI-compatible API key
# For OpenRouter: https://openrouter.ai/keys
# For OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-or-v1-...

# Default model for examples (any OpenRouter-compatible model ID)
DEFAULT_EXAMPLES_MODEL=Sber/GigaChat-Max-V2

# Models for multi-model examples (e.g. llm_council_example.py)
DEFAULT_EXAMPLES_MODEL_1=minimax/minimax-m2.5
DEFAULT_EXAMPLES_MODEL_2=openai/gpt-4o
DEFAULT_EXAMPLES_MODEL_3=qwen/qwen3.5-plus-02-15

# OpenAI-compatible API base URL (defaults to OpenRouter if not set)
# For OpenRouter: https://openrouter.ai/api/v1
# For OpenAI: https://api.openai.com/v1
# For local LLMs: http://localhost:11434/v1 (Ollama), http://localhost:1234/v1 (LM Studio)
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Local LLM configuration (Ollama, LM Studio, vLLM, etc.)
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3

# LangFuse tracing (optional) - Enable observability/tracing
# Set ENABLE_LANGFUSE to True to enable tracing
ENABLE_LANGFUSE=False
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
