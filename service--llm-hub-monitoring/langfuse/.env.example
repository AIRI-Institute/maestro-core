# Langfuse Self-Hosted Configuration
# Copy this to .env and update values as needed

# Langfuse host URL (when running locally with docker-compose)
LANGFUSE_HOST=http://localhost:3000

# Host IP for Minio access (set to your IP if accessing from another machine)
LANGFUSE_HOST_IP=localhost

# Langfuse credentials (create these after first login to the UI)
LANGFUSE_PUBLIC_KEY=your-public-key-here
LANGFUSE_SECRET_KEY=your-secret-key-here
LANGFUSE_PROJECT_ID=your-project-id-here

# Enable/disable Langfuse tracing
LANGFUSE_ENABLED=true

# Capture full prompts and responses (set to false for privacy)
LANGFUSE_CAPTURE_CONTENT=true

LANGFUSE_S3_BATCH_EXPORT_ENABLED=true
